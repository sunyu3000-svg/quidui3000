.calendar-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.calendar-content {
  width: 100%;
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.header-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #6b7280;
  background: #f3f4f6;
  border-radius: 50%;
}

.header-btn:active {
  background: #e5e7eb;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
}

.calendar-weekdays {
  display: flex;
  margin-bottom: 16rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #6b7280;
  padding: 16rpx 0;
}

.weekday.weekend {
  color: #dc2626;
}

.calendar-days {
  display: flex;
  flex-wrap: wrap;
}

.day-item {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-day {
  width: 100%;
  height: 100%;
}

.day-content {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-num {
  font-size: 28rpx;
  color: #1f2937;
}

.day-content.weekend-day .day-num {
  color: #dc2626;
}

.day-content.today {
  background: #fef3c7;
}

.day-content.today .day-num {
  color: #d97706;
  font-weight: 600;
}

.day-content.selected {
  background: #dc2626;
}

.day-content.selected .day-num {
  color: white;
  font-weight: 600;
}

.day-content.selected.weekend-day .day-num {
  color: white;
}

.festival {
  font-size: 18rpx;
  color: #dc2626;
  position: absolute;
  bottom: 4rpx;
  white-space: nowrap;
}

.day-content.selected .festival {
  color: rgba(255, 255, 255, 0.8);
}