.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.share-btn {
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #ffffff;
}

.stats-overview {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.overview-card {
  flex: 1;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.overview-card.main {
  flex: 1.2;
  background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
}

.overview-card.main .overview-icon,
.overview-card.main .overview-value,
.overview-card.main .overview-label {
  color: #ffffff;
}

.overview-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.overview-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.overview-label {
  font-size: 22rpx;
  color: #9ca3af;
}

.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 24rpx;
}

.match-result {
  display: flex;
  justify-content: space-around;
}

.result-item {
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
}

.result-item.win {
  background: #d1fae5;
}

.result-item.draw {
  background: #fef3c7;
}

.result-item.loss {
  background: #fee2e2;
}

.result-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.result-label {
  font-size: 26rpx;
  color: #6b7280;
}

.location-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.location-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.location-info {
  display: flex;
  justify-content: space-between;
}

.location-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1f2937;
}

.location-count {
  font-size: 24rpx;
  color: #9ca3af;
}

.location-progress {
  height: 12rpx;
  background: #f3f4f6;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #dc2626 0%, #ef4444 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.attendance-grid {
  display: flex;
  justify-content: space-around;
}

.attendance-item {
  text-align: center;
}

.attendance-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #dc2626;
  margin-bottom: 8rpx;
}

.attendance-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.rank-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #ffffff;
  margin-right: 20rpx;
}

.player-info {
  flex: 1;
}

.player-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 4rpx;
}

.player-detail {
  font-size: 22rpx;
  color: #9ca3af;
}

.player-rate {
  font-size: 32rpx;
  font-weight: 700;
  color: #dc2626;
}