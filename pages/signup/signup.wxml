<view class="signup-container">
  <view class="header">
    <view class="header-title">活动报名</view>
    <view class="header-subtitle">选择一个活动参与</view>
    <view class="header-actions">
      <button wx:if="{{isAdmin}}" class="action-btn" bindtap="showSearchModal">📋 历史活动</button>
      <button wx:if="{{isAdmin}}" class="action-btn primary" bindtap="showAddActivityModal">+ 发布活动</button>
    </view>
  </view>
  
  <!-- 查询弹窗 -->
  <view class="modal-overlay" wx:if="{{showSearch}}" bindtap="closeSearchModal">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">查询历史活动</text>
        <text class="modal-close" bindtap="closeSearchModal">×</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">选择年月</text>
          <picker mode="date" fields="month" value="{{searchMonth}}" bindchange="onMonthChange">
            <view class="picker-value">{{formattedSearchMonth || '请选择年月'}}</view>
          </picker>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn btn-cancel" bindtap="closeSearchModal">取消</button>
        <button class="btn btn-confirm" bindtap="doSearch">查询</button>
      </view>
    </view>
  </view>

  <view class="activities-list" wx:if="{{!loading}}">
    <view 
      class="activity-card {{(item.status === 'ended' || item.status === '已结束') ? 'ended' : ''}}" 
      wx:for="{{activities}}" 
      wx:key="_id" 
      bindtap="goToDetail"
      data-activity="{{item}}"
    >
      <view class="activity-header">
        <view class="activity-title">{{item.title}}</view>
        <view class="activity-status">{{item.status || '报名中'}}</view>
      </view>
      
      <view class="activity-info">
        <view class="info-item">
          <text class="info-icon date-icon">📅</text>
          <text class="info-text">{{item.date || '暂无日期'}}</text>
        </view>
        <view class="info-item">
          <text class="info-icon time-icon">🕐</text>
          <text class="info-text">{{item.time}}</text>
        </view>
        <view class="info-item">
          <text class="info-icon location-icon">📍</text>
          <text class="info-text">{{item.location}}</text>
        </view>
      </view>

      <view class="activity-progress">
        <view class="progress-bar">
          <view 
            class="progress-fill" 
            style="width: {{item.signupCount ? (item.signupCount / item.maxPlayers * 100) : 0}}%"
          ></view>
        </view>
        <view class="progress-text">{{item.signupCount || 0}}/{{item.maxPlayers || 20}} 人</view>
      </view>

      <view class="activity-footer">
        <text class="activity-desc">{{item.description || '暂无描述'}}</text>
        <view class="arrow">→</view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{activities.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无活动</text>
    </view>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text class="loading-icon">⏳</text>
    <text class="loading-text">加载中...</text>
  </view>

  <view class="modal" wx:if="{{showAddModal}}" bindtap="closeAddModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-title">发布新活动</view>

      <view class="form-item">
        <text class="form-label">活动标题</text>
        <input class="form-input" placeholder="请输入活动标题" value="{{newActivity.title}}" bindinput="onActivityTitleInput" bindfocus="showTitleSuggestions" />
        <view class="suggestions" wx:if="{{showTitleSuggestions && historyTitles.length > 0}}">
          <view class="suggestion-item" wx:for="{{historyTitles}}" wx:key="value" bindtap="selectSuggestion" data-field="title" data-value="{{item.value}}">
            <text>{{item.value}}</text>
          </view>
        </view>
      </view>

      <view class="form-item">
          <text class="form-label">活动时间</text>
          <view class="picker-input" bindtap="openCalendar">
            <text wx:if="{{newActivity.date}}">📅 {{newActivity.date}}</text>
            <text wx:else class="placeholder">📅 点击选择日期</text>
          </view>
          <picker mode="time" value="{{newActivity.timeValue}}" bindchange="onTimeChange">
            <view class="picker-input">
              <text wx:if="{{newActivity.timeValue}}">🕐 {{newActivity.timeValue}}</text>
              <text wx:else class="placeholder">🕐 点击选择时间</text>
            </view>
          </picker>
        </view>

      <view class="form-item">
        <text class="form-label">活动地点</text>
        <view class="picker-input" bindtap="chooseLocation">
          <text wx:if="{{newActivity.location}}">📍 {{newActivity.location}}</text>
          <text wx:else class="placeholder">📍 点击选择地点</text>
        </view>
        <view wx:if="{{showLocationHistory}}" class="dropdown-list">
          <view 
            class="dropdown-item" 
            wx:for="{{historyLocations}}" 
            wx:key="value" 
            bindtap="selectLocation" 
            data-value="{{item.value}}"
          >
            <text>{{item.value}}</text>
            <text class="dropdown-count">使用{{item.count}}次</text>
          </view>
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">活动类型</text>
        <input 
          class="form-input" 
          placeholder="⚽ 输入活动类型" 
          value="{{newActivity.activityType}}" 
          bindinput="onActivityTypeInput" 
          bindfocus="onActivityTypeFocus"
        />
        <view wx:if="{{showActivityTypeHistory}}" class="dropdown-list">
          <view 
            class="dropdown-item" 
            wx:for="{{historyActivityTypes}}" 
            wx:key="value" 
            bindtap="selectActivityType" 
            data-value="{{item.value}}"
          >
            <text>{{item.value}}</text>
            <text class="dropdown-count">使用{{item.count}}次</text>
          </view>
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">收费标准</text>
        <input 
          class="form-input" 
          placeholder="💰 输入收费标准" 
          value="{{newActivity.fee}}" 
          bindinput="onActivityFeeInput" 
          bindfocus="onFeeFocus"
        />
        <view wx:if="{{showFeeHistory}}" class="dropdown-list">
          <view 
            class="dropdown-item" 
            wx:for="{{historyFees}}" 
            wx:key="value" 
            bindtap="selectFee" 
            data-value="{{item.value}}"
          >
            <text>{{item.value}}</text>
            <text class="dropdown-count">使用{{item.count}}次</text>
          </view>
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">活动描述</text>
        <textarea class="form-textarea" placeholder="请输入活动描述" value="{{newActivity.description}}" bindinput="onActivityDescInput" />
      </view>

      <view class="form-item">
        <text class="form-label">最大人数</text>
        <view class="player-options">
          <button class="player-option" wx:for="{{playerOptions}}" wx:key="value" bindtap="selectPlayers" data-value="{{item.value}}">{{item.label}}</button>
        </view>
        <view wx:if="{{showPlayerHistory}}" class="history-list">
          <text class="history-subtitle">👥 历史人数</text>
          <view class="history-item" wx:for="{{historyPlayers}}" wx:key="value" bindtap="selectPlayers" data-value="{{item.value}}">
            <text>{{item.value}}人</text>
            <text class="history-count">使用{{item.count}}次</text>
          </view>
          <view wx:if="{{historyPlayers.length === 0}}" class="history-empty">
            <text>暂无历史人数，请手动输入</text>
          </view>
        </view>
        <input class="form-input mt-10" type="number" placeholder="点击上方按钮或手动输入人数" value="{{newActivity.maxPlayers}}" bindinput="onActivityMaxPlayersInput" bindfocus="showPlayerHistoryTap" />
      </view>

      <view class="modal-buttons">
        <button class="modal-btn cancel" bindtap="closeAddModal">取消</button>
        <button class="modal-btn confirm" bindtap="addActivity">发布</button>
      </view>
    </view>
  </view>

  <calendar 
    show="{{showCalendar}}" 
    selected-date="{{newActivity.date}}"
    bind:select="onCalendarSelect" 
    bind:close="closeCalendar" 
  />
</view>