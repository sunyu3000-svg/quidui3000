.signup-container {
  min-height: 100vh;
  background: #f7f7f8;
}

.header {
  background: #2c3e50;
  padding: 48rpx 32rpx 40rpx;
  color: white;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.header-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.action-btn {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.75);
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  font-weight: 400;
}

.action-btn.primary {
  background: #dc2626;
  color: white;
  font-weight: 500;
  padding: 16rpx 34rpx;
}

/* 查询弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c3e50;
}

.modal-close {
  font-size: 48rpx;
  color: #2c3e50;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #2c3e50;
  margin-bottom: 16rpx;
  display: block;
}

.picker-value {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #2c3e50;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx 32rpx;
}

.btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.btn-cancel {
  background: #f5f5f5;
  color: #2c3e50;
}

.btn-confirm {
  background: #dc3545;
  color: white;
}

.activities-list {
  padding: 20rpx;
  margin-top: -40rpx;
}

.activity-row {
  position: relative;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  align-items: stretch;
}

.activity-slide {
  position: relative;
  z-index: 2;
  will-change: transform;
  width: 100%;
  pointer-events: auto;
}

.edit-btn {
  position: absolute;
  right: 140rpx;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background: #f59e0b;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.edit-icon {
  color: white;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background: #dc2626;
  border-radius: 0 16rpx 16rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  box-shadow: inset 4rpx 0 8rpx rgba(0,0,0,0.08);
}

.delete-icon {
  color: white;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.activity-card {
  background: white;
  border-radius: 12rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.activity-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #2c3e50;
}

.activity-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  background: #fff3cd;
  color: #856404;
  border-radius: 20rpx;
}

/* 已结束活动样式 */
.activity-card.ended {
  opacity: 0.85;
}

.activity-card.ended .activity-title,
.activity-card.ended .info-icon,
.activity-card.ended .info-text,
.activity-card.ended .progress-text,
.activity-card.ended .activity-desc,
.activity-card.ended .arrow {
  color: #b0b8c0;
}

.activity-card.ended .activity-status {
  background: #e9ecef;
  color: #b0b8c0;
}

.activity-info {
  display: flex;
  gap: 40rpx;
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-icon {
  font-size: 22rpx;
  color: #2c3e50;
}

.info-text {
  font-size: 26rpx;
  color: #2c3e50;
}

.activity-progress {
  margin-bottom: 20rpx;
}

.progress-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #dc3545;
  border-radius: 6rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #2c3e50;
  margin-top: 8rpx;
  text-align: right;
}

.activity-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.activity-desc {
  font-size: 24rpx;
  color: #2c3e50;
  flex: 1;
}

.arrow {
  font-size: 28rpx;
  color: #2c3e50;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #2c3e50;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #2c3e50;
}

.add-btn {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  color: white;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
}

.add-btn::after {
  border: none;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-height: 85vh;
  background: white;
  border-radius: 16rpx;
  padding: 36rpx;
  overflow-y: auto;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 32rpx;
  color: #2c3e50;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #2c3e50;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-input {
  height: 88rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.placeholder {
  color: #2c3e50;
}

.player-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.player-option {
  padding: 16rpx 28rpx;
  background: #f8f9fa;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #2c3e50;
}

.player-option::after {
  border: none;
}

.player-option:active {
  background: #dc3545;
  color: white;
  border-color: #dc3545;
}

.dropdown-list {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-top: 16rpx;
}

.dropdown-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
}

.dropdown-item:active {
  background: #e9ecef;
}

.dropdown-count {
  font-size: 22rpx;
  color: #2c3e50;
}

.suggestions {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-top: 16rpx;
}

.suggestion-item {
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
}

.suggestion-item:active {
  background: #e9ecef;
}

.history-list {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-top: 16rpx;
}

.history-subtitle {
  font-size: 24rpx;
  color: #2c3e50;
  margin-bottom: 12rpx;
  display: block;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

.history-item:active {
  background: #e9ecef;
}

.history-count {
  font-size: 22rpx;
  color: #2c3e50;
}

.history-empty {
  padding: 20rpx;
  text-align: center;
  color: #2c3e50;
  font-size: 24rpx;
}

.modal-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.modal-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #2c3e50;
}

.modal-btn.cancel::after {
  border: none;
}

.modal-btn.confirm {
  background: #dc3545;
  color: white;
}

.modal-btn.confirm::after {
  border: none;
}

.mt-10 {
  margin-top: 10rpx;
}