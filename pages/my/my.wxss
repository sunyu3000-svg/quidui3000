.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: #f7f7f8;
}

/* ===== 用户头部 ===== */
.user-section {
  background: #2c3e50;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.auth-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.auth-area:active {
  opacity: 0.8;
}

.avatar-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn {
  background: none;
  border: none;
  padding: 0;
}

.avatar-btn::after {
  border: none;
}

.avatar-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 56rpx;
  color: rgba(255, 255, 255, 0.4);
}

.nickname-area {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.nickname-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.nickname-placeholder-wrap {
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 8rpx;
}

.nickname-placeholder-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.edit-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-left: 8rpx;
}

.user-name {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 500;
}

.nickname {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.admin-tag {
  display: inline-block;
  background: rgba(255, 255, 255, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  margin-top: 12rpx;
}

.admin-tag text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ===== 表单区域 ===== */
.form-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.form-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 24rpx;
}

.login-hint-container {
  padding: 32rpx;
  text-align: center;
}

.login-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-label {
  font-size: 28rpx;
  color: #666;
}

.form-input {
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.picker-content {
  font-size: 28rpx;
}

.placeholder {
  color: #ccc;
}

.save-btn {
  width: 100%;
  height: 84rpx;
  background: #dc2626;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 24rpx;
}

.save-btn::after {
  border: none;
}

/* ===== 管理员区域 ===== */
.admin-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.admin-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.admin-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c3e50;
}

.add-admin-btn {
  height: 60rpx;
  padding: 0 24rpx;
  background: #dc2626;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 26rpx;
  line-height: 60rpx;
}

.add-admin-btn::after {
  border: none;
}

.admin-list {
  margin-bottom: 16rpx;
}

.admin-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.admin-actions {
  display: flex;
  align-items: center;
}

.cannot-delete {
  font-size: 22rpx;
  color: #ccc;
}

.admin-info {
  display: flex;
  flex-direction: column;
}

.admin-name {
  font-size: 28rpx;
  color: #333;
}

.admin-role {
  font-size: 22rpx;
  color: #999;
  margin-top: 2rpx;
}

.delete-admin-btn {
  height: 52rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  color: #999;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 52rpx;
}

.delete-admin-btn::after {
  border: none;
}

.admin-empty {
  padding: 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}

.admin-tips {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

.admin-tips .tips-title {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #666;
  margin-bottom: 12rpx;
}

.admin-tips .tips-list {
  padding-left: 12rpx;
}

.admin-tips .tips-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 6rpx;
}

.admin-tips .tips-item:last-child {
  margin-bottom: 0;
}

.admin-tips .tips-item .number {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  background: #dc2626;
  color: #ffffff;
  border-radius: 50%;
  font-size: 18rpx;
  font-weight: 700;
  margin-right: 10rpx;
}

/* ===== 弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 580rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 36rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  color: #2c3e50;
  margin-bottom: 24rpx;
}

.modal-input {
  width: 100%;
  height: 76rpx;
  font-size: 30rpx;
  text-align: center;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  margin-bottom: 24rpx;
}

.modal-buttons {
  display: flex;
  gap: 16rpx;
}

.modal-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.modal-btn.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm-btn {
  background: #dc2626;
  color: #ffffff;
}

.modal-btn::after {
  border: none;
}

/* ===== 用户选择弹窗 ===== */
.user-select-modal {
  width: 580rpx;
  max-height: 700rpx;
}

.user-list {
  max-height: 500rpx;
  overflow-y: auto;
  margin-bottom: 16rpx;
}

.user-item {
  display: flex;
  align-items: center;
  padding: 18rpx 14rpx;
  border-radius: 10rpx;
}

.user-item:active {
  background: #f5f5f5;
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.user-avatar-placeholder {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.user-avatar-placeholder text {
  font-size: 26rpx;
  color: #999;
}

.user-item .user-name {
  font-size: 28rpx;
  color: #333;
  text-align: left;
}

/* ========== 活动归集 ========== */

.archive-section {
  background: white;
  border-radius: 16rpx;
  margin: 0 32rpx 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c3e50;
}

.archive-actions {
  display: flex;
  gap: 20rpx;
}

.archive-btn {
  flex: 1;
  height: 76rpx;
  background: #f0f2f5;
  color: #2c3e50;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
}

.archive-btn::after {
  border: none;
}

.archive-btn.primary {
  background: #dc2626;
  color: white;
  font-weight: 500;
}

.archive-desc {
  display: block;
  margin-top: 20rpx;
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
}

/* 归集弹窗 */
.archive-modal {
  width: 85%;
}

.archive-form-item {
  margin-bottom: 20rpx;
}

.archive-form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.archive-form-input {
  width: 100%;
  height: 80rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.archive-warning {
  display: block;
  font-size: 24rpx;
  color: #dc2626;
  background: #fff5f5;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

/* 历史归集列表 */
.seasons-modal {
  width: 88%;
  max-height: 75vh;
}

.seasons-list {
  max-height: 55vh;
}

.seasons-empty {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.season-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.season-item:last-child {
  border-bottom: none;
}

.season-info {
  flex: 1;
}

.season-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.season-date {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.season-stats {
  display: flex;
  gap: 16rpx;
  margin-right: 12rpx;
}

.season-stat {
  font-size: 24rpx;
  color: #666;
  background: #f0f2f5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.season-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.season-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.season-delete {
  font-size: 24rpx;
  color: #dc2626;
  padding: 4rpx 12rpx;
}

/* 归集详情弹窗 */
.season-detail-modal {
  width: 88%;
  max-height: 80vh;
}

.season-detail-date {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.season-detail-stats {
  display: flex;
  justify-content: center;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
}

.sds-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sds-num {
  font-size: 34rpx;
  font-weight: 700;
  color: #2c3e50;
}

.sds-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.sds-divider {
  width: 1rpx;
  height: 40rpx;
  background: #e0e0e0;
  align-self: center;
}

.detail-section {
  margin-bottom: 20rpx;
}

.detail-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.detail-section-title.detail-dove-title {
  color: #dc2626;
}

.detail-player-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-player-item:last-child {
  border-bottom: none;
}

/* 排行前三名样式 */
.detail-player-item.rank-1 {
  background: #fffbf0;
  border-radius: 8rpx;
  padding: 14rpx 12rpx;
  margin-bottom: 4rpx;
}

.detail-player-item.rank-2 {
  background: #f8f9fa;
  border-radius: 8rpx;
  padding: 14rpx 12rpx;
  margin-bottom: 4rpx;
}

.detail-player-item.rank-3 {
  background: #fff8f0;
  border-radius: 8rpx;
  padding: 14rpx 12rpx;
  margin-bottom: 4rpx;
}

.detail-player-rank {
  font-size: 22rpx;
  font-weight: 600;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  margin-right: 16rpx;
  color: #666;
  background: #f0f2f5;
}

.detail-player-rank.rank-1 {
  color: #fff;
  background: #f5a623;
}

.detail-player-rank.rank-2 {
  color: #fff;
  background: #a8a8a8;
}

.detail-player-rank.rank-3 {
  color: #fff;
  background: #cd7f32;
}

.detail-player-rank.dove-rank {
  color: #fff;
  background: #dc2626;
}

.detail-player-name {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.detail-player-count {
  font-size: 24rpx;
  color: #666;
}

.detail-player-count.dove-count {
  color: #dc2626;
}

.dove-item {
  background: #fff5f5;
  border-radius: 8rpx;
  padding: 14rpx 12rpx;
  margin-bottom: 4rpx;
}

.detail-activity-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-activity-item:last-child {
  border-bottom: none;
}

.da-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.da-num {
  font-size: 22rpx;
  color: #999;
  width: 36rpx;
  text-align: center;
}

.da-title {
  font-size: 26rpx;
  color: #333;
}

.da-date {
  font-size: 22rpx;
  color: #999;
}

.da-count {
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
}
