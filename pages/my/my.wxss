.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: #f7f7f8;
}

/* ===== 用户头部 ===== */
.user-section {
  background: #2c3e50;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.auth-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.auth-area:active {
  opacity: 0.8;
}

.avatar-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn {
  background: none;
  border: none;
  padding: 0;
}

.avatar-btn::after {
  border: none;
}

.avatar-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 56rpx;
  color: rgba(255, 255, 255, 0.4);
}

.nickname-area {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.nickname-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.nickname-placeholder-wrap {
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 8rpx;
}

.nickname-placeholder-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.edit-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-left: 8rpx;
}

.user-name {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 500;
}

.nickname {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.admin-tag {
  display: inline-block;
  background: rgba(255, 255, 255, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  margin-top: 12rpx;
}

.admin-tag text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ===== 表单区域 ===== */
.form-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.form-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c3e50;
  margin-bottom: 24rpx;
}

.login-hint-container {
  padding: 32rpx;
  text-align: center;
}

.login-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-label {
  font-size: 28rpx;
  color: #666;
}

.form-input {
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.picker-content {
  font-size: 28rpx;
}

.placeholder {
  color: #ccc;
}

.save-btn {
  width: 100%;
  height: 84rpx;
  background: #dc2626;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 24rpx;
}

.save-btn::after {
  border: none;
}

/* ===== 管理员区域 ===== */
.admin-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.admin-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.admin-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c3e50;
}

.add-admin-btn {
  height: 60rpx;
  padding: 0 24rpx;
  background: #dc2626;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 26rpx;
  line-height: 60rpx;
}

.add-admin-btn::after {
  border: none;
}

.admin-list {
  margin-bottom: 16rpx;
}

.admin-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.admin-actions {
  display: flex;
  align-items: center;
}

.cannot-delete {
  font-size: 22rpx;
  color: #ccc;
}

.admin-info {
  display: flex;
  flex-direction: column;
}

.admin-name {
  font-size: 28rpx;
  color: #333;
}

.admin-role {
  font-size: 22rpx;
  color: #999;
  margin-top: 2rpx;
}

.delete-admin-btn {
  height: 52rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  color: #999;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 52rpx;
}

.delete-admin-btn::after {
  border: none;
}

.admin-empty {
  padding: 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}

.admin-tips {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

.admin-tips .tips-title {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #666;
  margin-bottom: 12rpx;
}

.admin-tips .tips-list {
  padding-left: 12rpx;
}

.admin-tips .tips-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 6rpx;
}

.admin-tips .tips-item:last-child {
  margin-bottom: 0;
}

.admin-tips .tips-item .number {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  background: #dc2626;
  color: #ffffff;
  border-radius: 50%;
  font-size: 18rpx;
  font-weight: 700;
  margin-right: 10rpx;
}

/* ===== 弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 580rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 36rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  color: #2c3e50;
  margin-bottom: 24rpx;
}

.modal-input {
  width: 100%;
  height: 76rpx;
  font-size: 30rpx;
  text-align: center;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  margin-bottom: 24rpx;
}

.modal-buttons {
  display: flex;
  gap: 16rpx;
}

.modal-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.modal-btn.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm-btn {
  background: #dc2626;
  color: #ffffff;
}

.modal-btn::after {
  border: none;
}

/* ===== 用户选择弹窗 ===== */
.user-select-modal {
  width: 580rpx;
  max-height: 700rpx;
}

.user-list {
  max-height: 500rpx;
  overflow-y: auto;
  margin-bottom: 16rpx;
}

.user-item {
  display: flex;
  align-items: center;
  padding: 18rpx 14rpx;
  border-radius: 10rpx;
}

.user-item:active {
  background: #f5f5f5;
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.user-avatar-placeholder {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.user-avatar-placeholder text {
  font-size: 26rpx;
  color: #999;
}

.user-item .user-name {
  font-size: 28rpx;
  color: #333;
  text-align: left;
}
