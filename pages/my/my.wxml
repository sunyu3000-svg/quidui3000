<view class="container">
  <view class="user-section">
    <view wx:if="{{!hasUserInfo}}" class="auth-area" bindtap="onAuthTap">
      <view class="avatar-circle">
        <view class="avatar-placeholder">
          <text class="avatar-icon">登</text>
        </view>
      </view>
      <text class="user-name">点击授权登录</text>
    </view>
    <view wx:else class="avatar-area">
      <button 
        class="avatar-btn" 
        open-type="chooseAvatar" 
        bindchooseavatar="onChooseAvatar"
      >
        <view class="avatar-circle">
          <image wx:if="{{userInfo && userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
          <view wx:else class="avatar-placeholder">
            <text class="avatar-icon">{{userInfo && userInfo.nickName ? userInfo.nickName.charAt(0) : '用'}}</text>
          </view>
        </view>
      </button>
      <view class="nickname-area">
        <text 
          wx:if="{{userInfo && userInfo.nickName && userInfo.nickName !== ''}}" 
          class="nickname-text"
          bindtap="onNicknameTap"
        >{{userInfo.nickName}}</text>
        <view wx:else class="nickname-placeholder-wrap">
          <text class="nickname-placeholder-text">点击设置昵称</text>
        </view>
        <text class="edit-text" bindtap="onNicknameTap">修改</text>
      </view>
      
      <!-- 昵称编辑弹窗 -->
      <view wx:if="{{showNicknameModal}}" class="modal-overlay" bindtap="hideNicknameModal">
        <view class="modal-content" catchtap="stopPropagation">
          <view class="modal-title">修改昵称</view>
          <input 
            class="modal-input" 
            type="text" 
            value="{{editNickname}}" 
            placeholder="请输入昵称"
            focus="{{showNicknameModal}}"
            bindblur="onNicknameEditBlur"
            bindconfirm="saveNickname"
          />
          <view class="modal-buttons">
            <button class="modal-btn cancel-btn" bindtap="hideNicknameModal">取消</button>
            <button class="modal-btn confirm-btn" bindtap="saveNickname">保存</button>
          </view>
        </view>
      </view>

      <!-- 添加队长用户选择弹窗 -->
      <view wx:if="{{showAddAdminModal}}" class="modal-overlay" bindtap="hideAddAdminModal">
        <view class="modal-content user-select-modal" catchtap="stopPropagation">
          <view class="modal-title">选择用户添加为队长</view>
          <scroll-view scroll-y class="user-list">
            <view 
              class="user-item" 
              wx:for="{{userList}}" 
              wx:key="_id"
              bindtap="selectUserToAdd"
              data-nickname="{{item.nickName}}"
            >
              <image wx:if="{{item.avatarUrl}}" class="user-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
              <view wx:else class="user-avatar-placeholder">
                <text>{{item.nickName ? item.nickName.charAt(0) : '用'}}</text>
              </view>
              <view class="user-info-col">
                <text class="user-name">{{item.nickName || '未知用户'}}</text>
                <text class="user-phone" wx:if="{{item.phone}}">{{item.phone}}</text>
              </view>
            </view>
          </scroll-view>
          <view class="modal-buttons">
            <button class="modal-btn cancel-btn" bindtap="hideAddAdminModal">取消</button>
          </view>
        </view>
      </view>
    </view>
    <view class="admin-tag" wx:if="{{isAdmin}}">
      <text>{{isSuperAdmin ? '超级管理员' : '管理员'}}</text>
    </view>
  </view>

  <view class="form-section">
    <view class="form-title">个人信息</view>
    
    <view wx:if="{{!hasUserInfo}}" class="login-hint-container">
      <view class="login-hint">
        <text class="hint-text">请先点击上方头像区域进行微信授权登录</text>
      </view>
    </view>
    
    <view wx:else>
      <view class="form-item">
        <text class="form-label">球衣号码</text>
        <input class="form-input" type="number" placeholder="请输入球衣号码" placeholder-class="input-placeholder" value="{{formData.number}}" bindinput="onNumberInput" />
      </view>
      
      <view class="form-item">
        <text class="form-label">手机号码</text>
        <input class="form-input" type="number" placeholder="请输入手机号码" placeholder-class="input-placeholder" value="{{formData.phone}}" bindinput="onPhoneInput" />
      </view>
      
      <view class="form-item">
        <text class="form-label">场上位置</text>
        <picker mode="selector" range="{{positionOptions}}" bindchange="onPositionChange" value="{{positionOptions.indexOf(formData.position)}}">
          <view class="picker-content">
            <text wx:if="{{formData.position}}">{{formData.position}}</text>
            <text wx:else class="placeholder">请选择场上位置</text>
          </view>
        </picker>
      </view>
      
      <view class="form-item">
        <text class="form-label">球衣尺码</text>
        <picker mode="selector" range="{{sizeOptions}}" bindchange="onSizeChange" value="{{sizeOptions.indexOf(formData.size)}}">
          <view class="picker-content">
            <text wx:if="{{formData.size}}">{{formData.size}}</text>
            <text wx:else class="placeholder">请选择球衣尺码</text>
          </view>
        </picker>
      </view>
      
      <button class="save-btn" bindtap="saveData">保存</button>
    </view>
  </view>

  <view class="admin-section" wx:if="{{isSuperAdmin}}">
    <view class="admin-header">
      <text class="admin-title">队长管理</text>
      <button class="add-admin-btn" bindtap="addAdmin">添加队长</button>
    </view>
    <view class="admin-list" wx:if="{{admins.length > 0}}">
      <view class="admin-item" wx:for="{{admins}}" wx:key="_id">
        <view class="admin-info">
          <text class="admin-name">{{item.nickName || '未知'}}</text>
          <text class="admin-role">{{item.role === 'super' ? '超级管理员' : '队长'}}</text>
        </view>
        <view class="admin-actions">
          <button 
            class="delete-admin-btn" 
            wx:if="{{item.role !== 'super'}}" 
            bindtap="deleteAdmin" 
            data-id="{{item._id}}" 
            data-nickname="{{item.nickName}}"
          >删除</button>
          <text wx:else class="cannot-delete">不可删除</text>
        </view>
      </view>
    </view>
    <view class="admin-empty" wx:else>
      <text>暂无其他管理员，点击上方按钮添加</text>
    </view>
  </view>

  <!-- 活动归集 -->
  <view class="section archive-section" wx:if="{{isAdmin || isSuperAdmin}}">
    <view class="archive-header">
      <text class="archive-title">活动归集</text>
      <view class="archive-actions">
        <button class="archive-btn history" bindtap="loadSeasons">历史归集</button>
        <button class="archive-btn primary" bindtap="showArchiveModal" wx:if="{{isSuperAdmin}}">新建归集</button>
      </view>
    </view>
    <text class="archive-desc">归集后活动数据将保存为历史赛季，当前数据清零重新开始</text>
  </view>

  <!-- 归集弹窗 -->
  <view wx:if="{{showArchiveModal}}" class="modal-overlay" bindtap="cancelArchiveModal">
    <view class="modal-content archive-modal" catchtap="stopPropagation">
      <view class="modal-title">活动归集</view>
      <view class="archive-form-item">
        <text class="archive-form-label">归集名称</text>
        <input 
          class="archive-form-input" 
          type="text" 
          value="{{archiveName}}" 
          placeholder="如：2026赛季、测试赛季"
          bindinput="onArchiveNameInput"
          maxlength="20"
        />
      </view>
      <text class="archive-warning">归集后活动、签到、记账、鸽子榜数据将被清空，数据快照保存在历史归集中</text>
      <view class="modal-buttons">
        <button class="modal-btn cancel-btn" bindtap="cancelArchiveModal">取消</button>
        <button class="modal-btn confirm-btn" bindtap="confirmArchive" disabled="{{isArchiving}}">确认归集</button>
      </view>
    </view>
  </view>

  <!-- 历史归集列表弹窗 -->
  <view wx:if="{{showSeasonsModal}}" class="modal-overlay" bindtap="closeSeasonsModal">
    <view class="modal-content seasons-modal" catchtap="stopPropagation">
      <view class="modal-title">历史归集</view>
      <scroll-view scroll-y class="seasons-list">
        <view wx:if="{{seasons.length === 0}}" class="seasons-empty">
          <text>暂无历史归集</text>
        </view>
        <view 
          class="season-item" 
          wx:for="{{seasons}}" 
          wx:key="_id"
        >
          <view class="season-info" bindtap="showSeasonDetail" data-season="{{item}}">
            <text class="season-name">{{item.name}}</text>
            <text class="season-date">{{item.startDate}} ~ {{item.endDate}}</text>
          </view>
          <view class="season-stats" bindtap="showSeasonDetail" data-season="{{item}}">
            <text class="season-stat">{{item.stats.totalActivities}}场</text>
            <text class="season-stat">{{item.stats.totalParticipants}}人</text>
          </view>
          <view class="season-actions">
            <text class="season-arrow" bindtap="showSeasonDetail" data-season="{{item}}">›</text>
            <view class="season-delete" wx:if="{{isSuperAdmin}}" catchtap="deleteSeason" data-id="{{item._id}}" data-name="{{item.name}}">
              <text>删除</text>
            </view>
          </view>
        </view>
      </scroll-view>
      <view class="modal-buttons">
        <button class="modal-btn cancel-btn" bindtap="closeSeasonsModal">关闭</button>
      </view>
    </view>
  </view>

  <!-- 归集详情弹窗 -->
  <view wx:if="{{showSeasonDetailModal}}" class="modal-overlay" bindtap="closeSeasonDetail">
    <view class="modal-content season-detail-modal" catchtap="stopPropagation">
      <view class="modal-title">{{currentSeasonDetail.name}}</view>
      <view class="season-detail-date">{{currentSeasonDetail.startDate}} ~ {{currentSeasonDetail.endDate}}</view>
      
      <view class="season-detail-stats">
        <view class="sds-item">
          <text class="sds-num">{{currentSeasonDetail.stats.totalActivities}}</text>
          <text class="sds-label">总活动</text>
        </view>
        <view class="sds-divider"></view>
        <view class="sds-item">
          <text class="sds-num">{{currentSeasonDetail.stats.totalParticipants}}</text>
          <text class="sds-label">参与人数</text>
        </view>
        <view class="sds-divider"></view>
        <view class="sds-item">
          <text class="sds-num">{{currentSeasonDetail.stats.totalFees}}</text>
          <text class="sds-label">队费余额</text>
        </view>
      </view>

      <view class="detail-section" wx:if="{{currentSeasonDetail.topPlayers.length > 0}}">
        <text class="detail-section-title">参与排行</text>
        <view class="detail-player-item rank-{{index + 1}}" wx:for="{{currentSeasonDetail.topPlayers}}" wx:key="nickName">
          <text class="detail-player-rank rank-{{index + 1}}">{{index + 1}}</text>
          <text class="detail-player-name">{{item.nickName}}</text>
          <text class="detail-player-count">{{item.count}}次</text>
        </view>
      </view>

      <view class="detail-section" wx:if="{{currentSeasonDetail.doveRankings.length > 0}}">
        <text class="detail-section-title detail-dove-title">鸽子榜</text>
        <view class="detail-player-item dove-item" wx:for="{{currentSeasonDetail.doveRankings}}" wx:key="nickName">
          <text class="detail-player-rank dove-rank">{{index + 1}}</text>
          <text class="detail-player-name">{{item.nickName}}</text>
          <text class="detail-player-count dove-count">{{item.count}}次</text>
        </view>
      </view>

      <view class="detail-section" wx:if="{{currentSeasonDetail.activities.length > 0}}">
        <text class="detail-section-title">活动列表</text>
        <view class="detail-activity-item" wx:for="{{currentSeasonDetail.activities}}" wx:key="title">
          <view class="da-info">
            <text class="da-num">{{index + 1}}</text>
            <text class="da-title">{{item.title}}</text>
            <text class="da-date">{{item.date}}</text>
          </view>
          <text class="da-count">{{item.signupCount}}人</text>
        </view>
      </view>

      <view class="modal-buttons">
        <button class="modal-btn cancel-btn" bindtap="closeSeasonDetail">返回</button>
      </view>
    </view>
  </view>

  <view class="admin-tips" wx:if="{{isSuperAdmin}}">
    <view class="tips-title">
      <text>使用说明</text>
    </view>
    <view class="tips-list">
      <view class="tips-item">
        <text class="number">1</text>
        <text>超级管理员可以添加和删除队长</text>
      </view>
      <view class="tips-item">
        <text class="number">2</text>
        <text>队长拥有记账管理权限</text>
      </view>
      <view class="tips-item">
        <text class="number">3</text>
        <text>普通成员可以报名活动和完善资料</text>
      </view>
    </view>
  </view>
</view>
