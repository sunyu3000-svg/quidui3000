.container {
  padding: 0;
  min-height: 100vh;
  background-color: #f7f7f8;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* ===== 顶部栏 ===== */
.header-image {
  position: relative;
  width: 100%;
  height: 240rpx;
  background: #2c3e50;
}

.header-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ===== 俱乐部卡片 ===== */
.club-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #ffffff;
  margin: -32rpx 20rpx 16rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 10;
}

.club-logo {
  width: 72rpx;
  height: 72rpx;
  background: #2c3e50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.logo-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}

.club-info {
  flex: 1;
}

.club-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c3e50;
  display: block;
  margin-bottom: 4rpx;
}

.club-stats {
  font-size: 24rpx;
  color: #999;
}

/* ===== 活动标题 ===== */
.activity-title-card {
  padding: 24rpx;
  background: #ffffff;
  margin: 0 20rpx 16rpx;
  border-radius: 12rpx;
}

.activity-title-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #2c3e50;
  display: block;
  margin-bottom: 6rpx;
}

.activity-date {
  font-size: 24rpx;
  color: #999;
}

/* ===== 信息卡片 ===== */
.info-card {
  background-color: #ffffff;
  margin: 0 20rpx 16rpx;
  border-radius: 12rpx;
  padding: 8rpx 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.info-value-wrap {
  flex: 1;
}

.nav-buttons {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-link {
  font-size: 24rpx;
  color: #dc2626;
  margin-right: 12rpx;
}

/* ===== 描述卡片 ===== */
.desc-card {
  background-color: #ffffff;
  margin: 0 20rpx 16rpx;
  border-radius: 12rpx;
  padding: 24rpx;
}

.author-info {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.author-avatar {
  width: 48rpx;
  height: 48rpx;
  background: #e0e0e0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.author-avatar-text {
  font-size: 22rpx;
  color: #999;
  font-weight: 600;
}

.author-detail {
  flex: 1;
}

.author-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.author-label {
  font-size: 20rpx;
  color: #bbb;
}

.desc-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* ===== 报名区域 ===== */
.signups-section {
  background-color: #ffffff;
  margin: 0 20rpx 16rpx;
  border-radius: 12rpx;
  padding: 24rpx;
}

.signups-tabs {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.tab {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.tab.active {
  background: #f5f5f5;
}

.tab-text {
  font-size: 26rpx;
  color: #999;
}

.tab.active .tab-text {
  color: #2c3e50;
  font-weight: 700;
}

.tab-count {
  font-size: 26rpx;
  color: #333;
  font-weight: 700;
  margin-left: 4rpx;
}

.tab-count.pending {
  color: #f5a623;
}

.tab-count.leave {
  color: #999;
}

.tab-divider {
  font-size: 22rpx;
  color: #ddd;
  margin: 0 8rpx;
}

.signups-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 8rpx 0;
}

.signup-item {
  width: calc(16.666% - 17rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 6rpx;
}

.signup-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  border: 2rpx solid #f0f0f0;
}

.signup-avatar.default-avatar {
  background: #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 26rpx;
  color: #999;
  font-weight: 600;
}

.number-badge {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  background: #dc2626;
  color: #ffffff;
  font-size: 16rpx;
  padding: 2rpx 6rpx;
  border-radius: 8rpx;
  font-weight: 700;
  border: 2rpx solid #ffffff;
}

.status-badge {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  background: #f5a623;
  color: #ffffff;
  font-size: 16rpx;
  padding: 2rpx 6rpx;
  border-radius: 8rpx;
  font-weight: 700;
  border: 2rpx solid #ffffff;
}

.status-badge.leave {
  background: #999;
}

.signup-name {
  font-size: 22rpx;
  color: #888;
  text-align: center;
}

.empty-state {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.empty-text {
  font-size: 24rpx;
  color: #aaa;
}

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  display: flex;
  gap: 12rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.ended-text {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 20rpx 0;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn.signup-btn {
  background: #dc2626;
}

.action-btn.signup-btn .btn-text {
  color: #ffffff;
}

.action-btn.signup-btn.active {
  background: #b91c1c;
}

.action-btn.pending-leave-btn {
  background: #ffffff;
  border: 1rpx solid #dc2626;
}

.action-btn.pending-leave-btn .btn-text {
  color: #dc2626;
}

.action-btn.pending-leave-btn.active {
  background: #fef2f2;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
}

/* ===== 操作菜单 ===== */
.action-menu {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.menu-content {
  width: 100%;
  background: #ffffff;
  border-radius: 16rpx 16rpx 0 0;
  padding: 16rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.menu-item {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-item.cancel {
  margin-top: 8rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-text.leave {
  color: #dc2626;
}

.menu-divider {
  height: 8rpx;
  background: #f5f5f5;
  margin: 4rpx 0;
}

/* ===== 成功弹窗 ===== */
.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 580rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  text-align: center;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2c3e50;
  display: block;
  margin-bottom: 24rpx;
}

.modal-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin-bottom: 24rpx;
}

.modal-hint {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 32rpx;
}

.modal-buttons {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel-btn {
  border-right: 1rpx solid #f0f0f0;
}

.modal-btn.cancel-btn text {
  font-size: 30rpx;
  color: #666;
}

.modal-btn.confirm-btn text {
  font-size: 30rpx;
  color: #dc2626;
  font-weight: 600;
}

/* ===== 评论区 ===== */
.comments-section {
  background: #ffffff;
  margin: 0 20rpx 16rpx;
  border-radius: 12rpx;
  padding: 24rpx;
}

.comments-header {
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.comments-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2c3e50;
}

.comments-list {
  display: flex;
  flex-direction: column;
}

.comment-item {
  display: flex;
  gap: 14rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.comment-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.comment-avatar-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #999;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.comment-nickname {
  font-size: 24rpx;
  font-weight: 600;
  color: #555;
}

.comment-time {
  font-size: 20rpx;
  color: #bbb;
}

.comment-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  word-break: break-all;
  margin-bottom: 8rpx;
}

.comment-content.reply {
  background: #f7f7f8;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
}

.reply-tag {
  color: #dc2626;
  font-weight: 500;
}

.comment-actions {
  display: flex;
  gap: 24rpx;
}

.comment-reply-btn {
  font-size: 22rpx;
  color: #999;
}

.comment-reply-btn:active {
  color: #dc2626;
}

.comment-delete-btn {
  font-size: 22rpx;
  color: #ccc;
}

.comment-delete-btn:active {
  color: #dc2626;
}

.comments-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.comments-empty-text {
  font-size: 24rpx;
  color: #aaa;
}

.comment-input-bar {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #f0f0f0;
}

.reply-hint {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #dc2626;
  padding: 6rpx 14rpx;
  margin-bottom: 10rpx;
  background: #fef2f2;
  border-radius: 8rpx;
}

.reply-cancel {
  font-size: 26rpx;
  color: #aaa;
}

.comment-input-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.comment-input {
  flex: 1;
  height: 68rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.comment-send-btn {
  height: 68rpx;
  padding: 0 28rpx;
  background: #dc2626;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.comment-send-btn::after {
  border: none;
}

.comment-send-btn:active {
  opacity: 0.85;
}
