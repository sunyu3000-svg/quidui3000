.container {
  padding: 0;
  min-height: 100vh;
  background-color: #f5f5f7;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.header-image {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #dc2626 0%, #b91c1c 50%, #991b1b 100%);
}

.header-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.3));
}

.header-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

.club-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background-color: #ffffff;
  margin: -40rpx 20rpx 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 10;
}

.club-logo {
  width: 90rpx;
  height: 90rpx;
  background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.club-info {
  flex: 1;
}

/* 活动主题卡片 */
.activity-title-card {
  padding: 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fef9c3 100%);
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #fbbf24;
  box-shadow: 0 4rpx 20rpx rgba(251, 191, 36, 0.15);
}

.activity-title-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 8rpx;
}

.activity-date {
  font-size: 26rpx;
  color: #6b7280;
}

.club-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 8rpx;
}

.club-stats {
  font-size: 26rpx;
  color: #9ca3af;
}

.info-card {
  background-color: #ffffff;
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f3f4f6;
}

.info-row:last-child {
  border-bottom: none;
}

.info-icon-wrap {
  font-size: 32rpx;
  margin-right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.info-content {
  flex: 1;
}

.info-label {
  font-size: 24rpx;
  color: #9ca3af;
  display: block;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
}

.view-count {
  font-size: 24rpx;
  color: #9ca3af;
}

.nav-buttons {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.nav-link {
  font-size: 24rpx;
  color: #dc2626;
}

.edit-link {
  font-size: 24rpx;
  color: #10b981;
}

.desc-card {
  background-color: #ffffff;
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
  padding: 24rpx;
}

.author-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.author-avatar {
  width: 60rpx;
  height: 60rpx;
  background-color: #f3f4f6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.author-detail {
  flex: 1;
}

.author-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  display: block;
  margin-bottom: 4rpx;
}

.author-stars {
  font-size: 20rpx;
  color: #f59e0b;
}

.desc-text {
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
}

.signups-section {
  background-color: #ffffff;
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
  padding: 24rpx;
}

.signups-tabs {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.tab {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
}

.tab.active {
  background-color: #f9fafb;
}

.tab-text {
  font-size: 28rpx;
  color: #6b7280;
}

.tab.active .tab-text {
  color: #1f2937;
  font-weight: bold;
}

.tab-count {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: bold;
  margin-left: 6rpx;
}

.tab-count.pending {
  color: #f59e0b;
}

.tab-count.leave {
  color: #6b7280;
}

.tab-divider {
  font-size: 24rpx;
  color: #d1d5db;
  margin: 0 12rpx;
}

.signups-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 10rpx 0;
}

.signup-item {
  width: calc(16.666% - 17rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 10rpx;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 8rpx;
}

.signup-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #f3f4f6;
}

.signup-avatar.default-avatar {
  background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

.number-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  background-color: #dc2626;
  color: #ffffff;
  font-size: 18rpx;
  padding: 4rpx 8rpx;
  border-radius: 10rpx;
  font-weight: bold;
  border: 2rpx solid #ffffff;
}

.status-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  background-color: #f59e0b;
  color: #ffffff;
  font-size: 18rpx;
  padding: 4rpx 8rpx;
  border-radius: 10rpx;
  font-weight: bold;
  border: 2rpx solid #ffffff;
}

.status-badge.leave {
  background-color: #6b7280;
}

.signup-name {
  font-size: 22rpx;
  color: #6b7280;
  text-align: center;
}

.empty-state {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #9ca3af;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  display: flex;
  gap: 12rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.ended-text {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 20rpx 0;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s ease;
}

.action-btn::after {
  border: none;
}

.action-btn.signup-btn {
  background-color: transparent;
  border: 2rpx solid #dc2626;
}

.action-btn.signup-btn .btn-icon,
.action-btn.signup-btn .btn-text {
  color: #dc2626;
}

.action-btn.signup-btn.active {
  background-color: transparent;
  border-color: #dc2626;
}

.action-btn.signup-btn.active .btn-icon,
.action-btn.signup-btn.active .btn-text {
  color: #dc2626;
}

.action-btn.pending-leave-btn {
  background-color: transparent;
  border: 2rpx solid #dc2626;
}

.action-btn.pending-leave-btn .btn-icon,
.action-btn.pending-leave-btn .btn-text {
  color: #dc2626;
}

.action-btn.pending-leave-btn.active {
  background-color: transparent;
  border-color: #dc2626;
}

.action-btn.pending-leave-btn.active .btn-icon,
.action-btn.pending-leave-btn.active .btn-text {
  color: #dc2626;
}

.btn-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: bold;
}

.action-menu {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.menu-content {
  width: 100%;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.menu-item {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-item.cancel {
  margin-top: 12rpx;
}

.menu-text {
  font-size: 32rpx;
  color: #374151;
}

.menu-text.leave {
  color: #dc2626;
}

.menu-divider {
  height: 16rpx;
  background-color: #f3f4f6;
  margin: 8rpx 0;
}

.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.modal-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1f2937;
  display: block;
  margin-bottom: 32rpx;
}

.modal-divider {
  height: 2rpx;
  background-color: #f3f4f6;
  margin-bottom: 32rpx;
}

.modal-hint {
  font-size: 28rpx;
  color: #9ca3af;
  display: block;
  margin-bottom: 40rpx;
}

.modal-buttons {
  display: flex;
  border-top: 2rpx solid #f3f4f6;
}

.modal-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel-btn {
  border-right: 2rpx solid #f3f4f6;
}

.modal-btn.cancel-btn text {
  font-size: 32rpx;
  color: #374151;
}

.modal-btn.confirm-btn text {
  font-size: 32rpx;
  color: #dc2626;
  font-weight: 500;
}
