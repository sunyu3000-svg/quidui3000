.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  color: #ffffff;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.player-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.player-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.player-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-right: 24rpx;
}

.player-info {
  flex: 1;
}

.player-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.player-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.player-number {
  font-size: 26rpx;
  font-weight: 600;
  color: #dc2626;
}

.player-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.meta-tag {
  font-size: 24rpx;
  color: #6b7280;
  background: #f3f4f6;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.player-contact {
  display: flex;
  align-items: center;
}

.contact-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.contact-text {
  font-size: 26rpx;
  color: #374151;
}

.player-action {
  margin-left: 20rpx;
}

.call-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #d1fae5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #9ca3af;
}