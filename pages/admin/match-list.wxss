.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  color: #ffffff;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.match-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.match-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.match-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-badge.finished {
  background: #d1fae5;
  color: #059669;
}

.status-badge.upcoming {
  background: #fef3c7;
  color: #d97706;
}

.match-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
}

.action-btn.edit {
  background: #dbeafe;
  color: #2563eb;
}

.action-btn.delete {
  background: #fee2e2;
  color: #dc2626;
}

.match-info {
  padding-top: 20rpx;
  border-top: 2rpx solid #f3f4f6;
}

.match-teams {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.team {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.score {
  font-size: 36rpx;
  font-weight: 700;
  color: #dc2626;
  padding: 0 24rpx;
}

.match-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.meta-item {
  font-size: 26rpx;
  color: #6b7280;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #9ca3af;
}