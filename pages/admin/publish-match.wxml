<view class="container">
  <view class="form-card">
    <view class="form-title">{{isEdit ? '编辑比赛' : '发布比赛'}}</view>
    
    <view class="form-item">
      <view class="form-label">📅 比赛日期 *</view>
      <picker mode="date" value="{{formData.date}}" bindchange="onDateChange">
        <view class="form-picker">
          {{formData.date || '请选择日期'}}
        </view>
      </picker>
    </view>
    
    <view class="form-item">
      <view class="form-label">🕐 比赛时间 *</view>
      <picker mode="time" value="{{formData.time}}" bindchange="onTimeChange">
        <view class="form-picker">
          {{formData.time || '请选择时间'}}
        </view>
      </picker>
    </view>
    
    <view class="form-item">
      <view class="form-label">🏠 主队名称 *</view>
      <input class="form-input" placeholder="请输入主队名称" value="{{formData.homeTeam}}" bindinput="onInput" data-field="homeTeam" />
    </view>
    
    <view class="form-item">
      <view class="form-label">👤 客队名称 *</view>
      <input class="form-input" placeholder="请输入客队名称" value="{{formData.awayTeam}}" bindinput="onInput" data-field="awayTeam" />
    </view>
    
    <view class="form-item">
      <view class="form-label">📍 场地名称 *</view>
      <input class="form-input" placeholder="请输入场地名称" value="{{formData.locationName}}" bindinput="onInput" data-field="locationName" />
    </view>
    
    <view class="form-item">
      <view class="form-label">🏟️ 场地地址 *</view>
      <input class="form-input" placeholder="请输入场地地址" value="{{formData.locationAddress}}" bindinput="onInput" data-field="locationAddress" />
    </view>
    
    <view class="form-item">
      <view class="form-label">📝 备注</view>
      <textarea class="form-textarea" placeholder="请输入比赛备注信息" value="{{formData.description}}" bindinput="onInput" data-field="description" />
    </view>
  </view>
  
  <view class="form-actions">
    <button class="btn cancel" bindtap="cancel">取消</button>
    <button class="btn confirm" bindtap="publishMatch">{{isEdit ? '保存修改' : '发布比赛'}}</button>
  </view>
</view>