<view class="container">
  <view class="header">
    <view class="header-title">🔐 管理中心</view>
    <view class="header-subtitle">厦门天涯足球队管理后台</view>
  </view>
  
  <view class="stats-card">
    <view class="stats-row">
      <view class="stat-item">
        <view class="stat-value">{{stats.matchCount}}</view>
        <view class="stat-label">比赛场次</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value">{{stats.playerCount}}</view>
        <view class="stat-label">球员人数</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value">{{stats.registeredCount}}</view>
        <view class="stat-label">已报名</view>
      </view>
    </view>
  </view>
  
  <view class="menu-section">
    <view class="section-title">比赛管理</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToPublishMatch">
        <view class="menu-icon">📝</view>
        <view class="menu-info">
          <view class="menu-title">发布比赛</view>
          <view class="menu-desc">创建新的比赛日程</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="goToMatchList">
        <view class="menu-icon">📋</view>
        <view class="menu-info">
          <view class="menu-title">比赛列表</view>
          <view class="menu-desc">管理所有比赛记录</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </view>
  
  <view class="menu-section">
    <view class="section-title">球员管理</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToPlayerList">
        <view class="menu-icon">👥</view>
        <view class="menu-info">
          <view class="menu-title">球员列表</view>
          <view class="menu-desc">查看和管理球员信息</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="goToRegisterManage">
        <view class="menu-icon">✅</view>
        <view class="menu-info">
          <view class="menu-title">报名管理</view>
          <view class="menu-desc">管理比赛报名情况</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </view>
  
  <view class="menu-section">
    <view class="section-title">数据统计</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goToStats">
        <view class="menu-icon">📊</view>
        <view class="menu-info">
          <view class="menu-title">球队统计</view>
          <view class="menu-desc">查看球队数据报表</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </view>
  
  <view class="menu-section">
    <view class="section-title">系统设置</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="clearCache">
        <view class="menu-icon">🗑️</view>
        <view class="menu-info">
          <view class="menu-title">清除缓存</view>
          <view class="menu-desc">清除本地数据缓存</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
      <view class="menu-item" bindtap="exportData">
        <view class="menu-icon">📤</view>
        <view class="menu-info">
          <view class="menu-title">导出数据</view>
          <view class="menu-desc">导出所有数据</view>
        </view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </view>
</view>