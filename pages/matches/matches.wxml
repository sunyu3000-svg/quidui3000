<view class="container">
  <view class="header">
    <view class="header-title">比赛日程</view>
    <view class="header-subtitle">厦门天涯足球队比赛信息</view>
  </view>
  
  <view class="match-list">
    <view class="match-card {{item.status}}" wx:for="{{matches}}" wx:key="id">
      <view class="match-status">
        <view class="status-badge {{item.status}}">
          {{item.status === 'finished' ? '已结束' : '未开始'}}
        </view>
        <view class="match-date">{{item.date}} {{item.time}}</view>
      </view>
      
      <view class="match-teams">
        <view class="team home">
          <view class="team-name">{{item.homeTeam}}</view>
          <view class="team-label">主场</view>
        </view>
        
        <view class="score-section">
          <view class="score {{item.status === 'upcoming' ? 'vs' : ''}}">
            <text wx:if="{{item.status === 'finished'}}">{{item.homeScore}} - {{item.awayScore}}</text>
            <text wx:else>VS</text>
          </view>
        </view>
        
        <view class="team away">
          <view class="team-name">{{item.awayTeam}}</view>
          <view class="team-label">客场</view>
        </view>
      </view>
      
      <view class="match-location">
        <text class="location-icon">📍</text>
        <text class="location-text">{{item.locationName || '未指定场地'}}</text>
      </view>
      
      <view class="match-footer" wx:if="{{item.status === 'finished'}}">
        <view class="result {{item.homeScore > item.awayScore ? 'win' : 'loss'}}">
          {{item.homeScore > item.awayScore ? '✓ 胜利' : '✗ 失败'}}
        </view>
      </view>
    </view>
  </view>
</view>