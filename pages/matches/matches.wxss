.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  color: #ffffff;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.match-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.match-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
}

.match-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
}

.match-card.upcoming::before {
  background: linear-gradient(180deg, #f59e0b 0%, #d97706 100%);
}

.match-card.finished::before {
  background: linear-gradient(180deg, #10b981 0%, #059669 100%);
}

.match-status {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-badge.finished {
  background: #d1fae5;
  color: #059669;
}

.status-badge.upcoming {
  background: #fef3c7;
  color: #d97706;
}

.match-date {
  font-size: 26rpx;
  color: #6b7280;
}

.match-teams {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.team {
  flex: 1;
  text-align: center;
}

.team-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.team-label {
  font-size: 22rpx;
  color: #9ca3af;
}

.score-section {
  padding: 0 40rpx;
}

.score {
  font-size: 48rpx;
  font-weight: 700;
  color: #dc2626;
}

.score.vs {
  color: #f59e0b;
}

.match-location {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.location-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.location-text {
  font-size: 26rpx;
  color: #6b7280;
}

.match-footer {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f3f4f6;
  display: flex;
  justify-content: center;
}

.result {
  font-size: 28rpx;
  font-weight: 600;
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
}

.result.win {
  background: #d1fae5;
  color: #059669;
}

.result.loss {
  background: #fee2e2;
  color: #dc2626;
}