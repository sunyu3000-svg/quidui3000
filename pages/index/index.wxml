<view class="container">
  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="club-name-bar">
      <text class="club-name-text">{{seasonName}}</text>
      <text class="club-slogan">热爱足球 · 享受运动</text>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{stats.totalActivities}}</text>
      <text class="stat-name">总活动</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.ongoingActivities}}</text>
      <text class="stat-name">进行中</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.activeUsers}}</text>
      <text class="stat-name">注册人数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.totalFees}}</text>
      <text class="stat-name">队费余额</text>
    </view>
  </view>

  <!-- 本周报名趋势 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">本周活动</text>
      <text class="card-sub">场次分布</text>
    </view>
    <view class="chart-bars">
      <view class="bar-item" wx:for="{{chartData.labels}}" wx:key="index">
        <text class="bar-value">{{chartData.data[index]}}</text>
        <view class="bar" style="height: {{chartData.data[index] * 15}}px;"></view>
        <text class="bar-label">{{item}}</text>
      </view>
    </view>
    <view class="chart-footer">
      <text>本周共{{stats.weeklyActivity}}场</text>
    </view>
  </view>

  <!-- 月度趋势 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">月度活动</text>
      <text class="card-sub">近12个月</text>
    </view>
    <scroll-view class="chart-scroll" scroll-x enable-flex>
      <view class="chart-bars-h">
        <view class="bar-item-h" wx:for="{{monthlyData.labels}}" wx:key="index">
          <text class="bar-value">{{monthlyData.data[index]}}</text>
          <view class="bar bar-blue" style="height: {{monthlyData.data[index] * 8}}px;"></view>
          <text class="bar-label">{{item}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 热门球员 -->
  <view class="card" wx:if="{{topPlayers.length > 0}}">
    <view class="card-header">
      <text class="card-title">参赛排行</text>
    </view>
    <view class="rank-list">
      <view
        class="rank-row"
        wx:for="{{topPlayers}}"
        wx:key="index"
        bindtap="goToUserProfile"
        data-user-id="{{item.userId || item._id}}"
        data-nick-name="{{item.nickName}}"
        data-avatar-url="{{item.avatarUrl}}"
      >
        <text class="rank-num {{index < 3 ? 'rank-top' : ''}}">{{index + 1}}</text>
        <view class="rank-avatar">
          <image wx:if="{{item.avatarUrl && item.avatarUrl.trim()}}" src="{{item.avatarUrl}}" mode="aspectFill" />
          <text wx:else class="rank-avatar-text">{{item.nickName ? item.nickName.charAt(0) : '?'}}</text>
        </view>
        <text class="rank-name">{{item.nickName || '未知'}}</text>
        <text class="rank-count">{{item.count}}场</text>
      </view>
    </view>
  </view>

  <!-- 鸽子榜 -->
  <view class="card" wx:if="{{doveRankings.length > 0}}">
    <view class="card-header">
      <text class="card-title">放鸽排行</text>
    </view>
    <view class="rank-list">
      <view
        class="rank-row"
        wx:for="{{doveRankings}}"
        wx:key="userId"
        wx:for-index="idx"
        bindtap="goToUserProfile"
        data-user-id="{{item.userId}}"
        data-nick-name="{{item.nickName}}"
        data-avatar-url="{{item.avatarUrl}}"
      >
        <text class="rank-num {{idx < 3 ? 'rank-dove' : ''}}">{{idx + 1}}</text>
        <view class="rank-avatar">
          <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" mode="aspectFill" />
          <text wx:else class="rank-avatar-text">{{item.nickName ? item.nickName.charAt(0) : '?'}}</text>
        </view>
        <text class="rank-name">{{item.nickName || '未知用户'}}</text>
        <text class="rank-count rank-dove-count">{{item.count}}次</text>
      </view>
    </view>
  </view>
</view>
