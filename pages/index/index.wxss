.container {
  padding: 0;
  min-height: 100vh;
  background-color: #f7f7f8;
  padding-bottom: 40rpx;
}

/* ===== 顶部栏 ===== */
.top-bar {
  background: #2c3e50;
  padding: 50rpx 32rpx 64rpx;
}

.club-name-bar {
  display: flex;
  flex-direction: column;
}

.club-name-text {
  font-size: 42rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.club-slogan {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
}

/* ===== 统计行 ===== */
.stats-row {
  display: flex;
  align-items: center;
  background: #ffffff;
  margin: -32rpx 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 28rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 2;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #2c3e50;
  line-height: 1.1;
}

.stat-name {
  font-size: 22rpx;
  color: #2c3e50;
  margin-top: 6rpx;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #eee;
}

/* ===== 卡片通用 ===== */
.card {
  background: #ffffff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 28rpx;
}

.card-header {
  display: flex;
  align-items: baseline;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c3e50;
}

.card-sub {
  font-size: 24rpx;
  color: #2c3e50;
  margin-left: 12rpx;
}

/* ===== 柱状图 ===== */
.chart-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 180rpx;
  padding: 10rpx 0;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-value {
  font-size: 22rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 6rpx;
}

.bar {
  width: 36rpx;
  background: #dc2626;
  border-radius: 4rpx 4rpx 0 0;
  min-height: 8rpx;
}

.bar-blue {
  background: #dc2626;
  border-radius: 4rpx 4rpx 0 0;
}

.bar-label {
  font-size: 22rpx;
  color: #2c3e50;
  margin-top: 8rpx;
}

.chart-footer {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 16rpx;
}

.chart-footer text {
  font-size: 24rpx;
  color: #2c3e50;
}

/* ===== 横向滚动图表 ===== */
.chart-scroll {
  width: 100%;
  white-space: nowrap;
}

.chart-bars-h {
  display: inline-flex;
  gap: 20rpx;
  padding: 10rpx 0;
}

.bar-item-h {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  min-width: 72rpx;
}

.chart-bars-h .bar {
  width: 40rpx;
  min-height: 8rpx;
}

/* ===== 排行列表 ===== */
.rank-list {
  display: flex;
  flex-direction: column;
}

.rank-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.rank-row:last-child {
  border-bottom: none;
}

.rank-row:active {
  background: #fafafa;
}

.rank-num {
  width: 48rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #bbb;
}

.rank-num.rank-top {
  color: #dc2626;
}

.rank-num.rank-dove {
  color: #999;
}

.rank-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin: 0 16rpx;
  overflow: hidden;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rank-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.rank-avatar-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #2c3e50;
}

.rank-name {
  flex: 1;
  font-size: 28rpx;
  color: #2c3e50;
  font-weight: 500;
}

.rank-count {
  font-size: 26rpx;
  color: #666;
  font-weight: 600;
}

.rank-dove-count {
  color: #999;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.4;
}

.empty-title {
  font-size: 30rpx;
  color: #2c3e50;
}

.empty-desc {
  font-size: 26rpx;
  color: #2c3e50;
  margin-top: 8rpx;
}

/* ===== 加载状态 ===== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #eee;
  border-top: 4rpx solid #dc2626;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #2c3e50;
  margin-top: 16rpx;
}

/* ===== 弹窗/表单（创建活动等）===== */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 620rpx;
  max-height: 85vh;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 36rpx;
  overflow-y: auto;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2c3e50;
  text-align: center;
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
  position: relative;
}

.form-label {
  font-size: 26rpx;
  color: #2c3e50;
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 76rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 140rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-input {
  width: 100%;
  height: 76rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.suggestions {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: #ffffff;
  border: 1rpx solid #e5e5e5;
  border-radius: 0 0 10rpx 10rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 10;
}

.suggestion-item {
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.suggestion-item:active {
  background: #fafafa;
}

.suggestion-item text {
  font-size: 28rpx;
  color: #2c3e50;
}

.dropdown-list {
  background: #ffffff;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  margin-top: 8rpx;
  overflow: hidden;
}

.dropdown-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-item:active {
  background: #f5f5f5;
}

.dropdown-count {
  font-size: 22rpx;
  color: #2c3e50;
}

.player-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.player-option {
  padding: 10rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #2c3e50;
}

.player-option::after {
  border: none;
}

.player-option:active {
  background: #dc2626;
  color: #ffffff;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.modal-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #2c3e50;
}

.modal-btn.confirm {
  background: #dc2626;
  color: #ffffff;
}

.modal-btn.cancel::after,
.modal-btn.confirm::after {
  border: none;
}

.history-tips {
  margin-top: 10rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #2c3e50;
}

/* ===== 活动列表（保留兼容）===== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c3e50;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.activity-count {
  font-size: 24rpx;
  color: #2c3e50;
}

.add-btn {
  height: 56rpx;
  padding: 0 24rpx;
  background: #dc2626;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 26rpx;
  line-height: 56rpx;
}

.add-btn::after {
  border: none;
}

.activity-list {
  padding: 0 24rpx 24rpx;
}

.swipe-container {
  position: relative;
  margin-bottom: 20rpx;
  overflow: hidden;
  border-radius: 16rpx;
}

.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 130rpx;
  background: #dc2626;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.delete-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.delete-text {
  font-size: 22rpx;
  color: #ffffff;
}

.activity-card {
  position: relative;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  z-index: 2;
}

.activity-card:active {
  opacity: 0.9;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c3e50;
}

.activity-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.activity-info {
  display: flex;
  gap: 32rpx;
  margin-bottom: 14rpx;
}

.activity-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 14rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  padding: 6rpx 14rpx;
  background: #f7f7f8;
  border-radius: 6rpx;
}

.meta-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #2c3e50;
}

.info-item {
  display: flex;
  align-items: center;
}

.info-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.info-text {
  font-size: 26rpx;
  color: #2c3e50;
}

.activity-desc {
  font-size: 26rpx;
  color: #2c3e50;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.activity-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.player-section {
  display: flex;
  align-items: center;
  flex: 1;
}

.player-progress {
  width: 180rpx;
  height: 8rpx;
  background: #eee;
  border-radius: 4rpx;
  margin-right: 14rpx;
  overflow: hidden;
}

.player-fill {
  height: 100%;
  background: #dc2626;
  border-radius: 4rpx;
}

.player-count {
  font-size: 24rpx;
  color: #888;
}

.action-arrow {
  padding: 8rpx;
}

.arrow {
  font-size: 32rpx;
  color: #2c3e50;
}
