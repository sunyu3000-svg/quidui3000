.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  color: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-content {
  flex: 1;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

.share-btn {
  background: rgba(255, 255, 255, 0.2);
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
}

.match-info-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.info-content {
  flex: 1;
}

.info-label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 30rpx;
  color: #1f2937;
  font-weight: 500;
}

.info-sub {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.register-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.title-sub {
  font-size: 26rpx;
  color: #9ca3af;
}

.count-badge {
  background: #fef3c7;
  color: #d97706;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.section-actions {
  margin-right: 10rpx;
}

.add-btn {
  background: #dc2626;
  color: #ffffff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  border: none;
}

.status-card {
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 24rpx;
}

.status-badge {
  font-size: 28rpx;
  font-weight: 600;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-bottom: 20rpx;
}

.status-badge.registered {
  background: #dcfce7;
  color: #22c55e;
}

.status-badge.leave {
  background: #fee2e2;
  color: #ef4444;
}

.status-badge.not-registered {
  background: #f3f4f6;
  color: #6b7280;
}

.status-actions {
  display: flex;
  gap: 16rpx;
}

.status-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
}

.status-btn.register {
  background: #e5e7eb;
  color: #6b7280;
}

.status-btn.register.primary {
  background: #dc2626;
  color: #ffffff;
}

.status-btn.leave {
  background: #fee2e2;
  color: #ef4444;
}

.status-btn.cancel {
  background: #e5e7eb;
  color: #6b7280;
}

.players-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.leave-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.players-list {
  margin-top: 20rpx;
}

.player-card {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.player-card:last-child {
  border-bottom: none;
}

.player-card.leave {
  opacity: 0.7;
}

.player-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.player-card.leave .player-avatar {
  background: linear-gradient(135deg, #9ca3af 0%, #6b7280 100%);
}

.avatar-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.player-info {
  flex: 1;
}

.player-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.player-meta {
  display: flex;
  gap: 12rpx;
}

.meta-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.meta-tag.number {
  background: #dbeafe;
  color: #2563eb;
}

.meta-tag.position {
  background: #fef3c7;
  color: #d97706;
}

.player-actions {
  display: flex;
  align-items: center;
}

.player-status {
  margin-right: 16rpx;
}

.my-tag {
  background: #dc2626;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.leave-badge {
  background: #fee2e2;
  color: #ef4444;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.admin-actions {
  margin-left: 16rpx;
}

.delete-btn {
  color: #ef4444;
  font-size: 26rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid #fecaca;
  border-radius: 8rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #9ca3af;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.modal-close {
  font-size: 36rpx;
  color: #9ca3af;
  padding: 8rpx;
}

.modal-body {
  padding: 32rpx;
}

.modal-body .form-item {
  margin-bottom: 24rpx;
}

.modal-body .form-label {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.modal-body .form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.modal-body .form-picker {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
}

.modal-body .picker-value {
  font-size: 28rpx;
  color: #9ca3af;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f3f4f6;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.modal-btn.cancel {
  background: #f3f4f6;
  color: #6b7280;
}

.modal-btn.confirm {
  background: #dc2626;
  color: #ffffff;
}